# TTS/STT 用（既存）
OPENAI_API_KEY=

# LLM プロバイダ選択（未設定 or claude が既定＝現行と完全同一）
# claude | openai-compat | codex
LLM_PROVIDER=

# LLM_PROVIDER=openai-compat のとき（Ollama / LM Studio / OpenAI / GitHub Models）
# 例(Ollama):   http://localhost:11434/v1
# 例(LM Studio): http://localhost:1234/v1
# 例(OpenAI):    https://api.openai.com/v1
OPENAI_COMPAT_BASE_URL=
# ローカル(Ollama/LM Studio)は不要。OpenAI/GitHub Models は必須
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# LLM_PROVIDER=codex のとき（任意・未指定は codex config の既定モデル）
CODEX_MODEL=
# 以下のチューニング変数はアプリ本体（サーバ/UI）は読まない（用途ごとの調整は ⚙️ 設定 → 用途ごとのモデルの詳細設定で行う）。
# CLI（scripts/generate-content.ts）のみ有効。
# codex の reasoning effort（low|medium|high|xhigh・未指定は medium）
CODEX_REASONING_EFFORT=
# codex の service tier（fast|standard・未指定は fast=priority 配信。無効な環境では黙って無視される）
CODEX_SERVICE_TIER=
# claude の CLI 用チューニング（LLM_PROVIDER=claude のとき。モデルは haiku|sonnet|opus・effort は low|medium|high|xhigh）
CLAUDE_MODEL=
CLAUDE_EFFORT=
