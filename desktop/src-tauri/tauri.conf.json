{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solo-eikaiwa",
  "version": "0.1.0",
  "identifier": "com.local.solo-eikaiwa.desktop",
  "build": {
    "frontendDist": "../fallback"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "solo-eikaiwa",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "userAgent": "solo-eikaiwa-desktop"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "-"
    }
  }
}
