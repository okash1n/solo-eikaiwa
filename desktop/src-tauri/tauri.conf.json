{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solo-eikaiwa",
  "version": "0.30.0",
  "identifier": "com.local.solo-eikaiwa.desktop",
  "build": {
    "frontendDist": "../fallback"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "solo-eikaiwa",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "userAgent": "solo-eikaiwa-desktop"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzNEM4QTU0RTI5NkZDMzEKUldReC9KYmlWSXBNODVWeUxZS09VcEtFOGlyVndxa1poSEh6WEFleHo2TXZGa0tpWFJvVUJiUzIK",
      "endpoints": [
        "https://github.com/btajp/solo-eikaiwa/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/solo-server"],
    "resources": {
      "resources/dist": "dist",
      "resources/content": "content",
      "resources/whisper-bin": "whisper-bin",
      "resources/provenance": "provenance"
    },
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "-"
    }
  }
}
